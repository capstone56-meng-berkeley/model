{
  "data_source": "drive",
  "local": {
    "images_dir": "data/images",
    "labels_csv": "data/labels.csv"
  },
  "temp_dir": "data/temp_images",
  "feature_cache": "data/feature_cache.npz",
  "model_dir": "models",
  "random_seed": 42,
  "img_size": 224,
  "batch_size": 16,
  "num_workers": 2,

  "google_drive": {
    "row_id_column": "A",
    "image_columns": ["D", "E", "F"],
    "column_types": {
      "D": "image",
      "E": "image",
      "F": "folder"
    }
  },

  "features": {
    "feature_columns": [],
    "label_columns": [],
    "column_types": {
      "Num_Cycles":          "categorical",
      "Cycle1_CRate (°C/s)": "categorical",
      "Cycle1_Rtemp":        "categorical",
      "Cycle1_Qtemp":        "categorical",
      "Cycle2_Rtemp (C)":    "categorical",
      "Cycle3_Rtemp":        "categorical",
      "Cycle3_Qtemp":        "categorical",
      "Cycle4_Qtemp":        "categorical",
      "Heat treatment type": "categorical",
      "ID":                  "unique_string"
    },
    "preprocessing": {
      "missing_data": {
        "column_drop_threshold": 0.95,
        "row_fill_threshold": 0.10,
        "numeric_fill_strategy": "mean",
        "categorical_fill_strategy": "mode",
        "mid_range_strategy": "fill"
      },
      "scaling": {
        "method": "standard",
        "enabled": true
      },
      "encoding": {
        "categorical": "onehot",
        "text": "tfidf",
        "unique_string": "label",
        "max_categories": 50
      }
    }
  },

  "extraction": {
    "backbones": ["vgg16"],
    "pooling": "avg",
    "parallel": false
  }
}
